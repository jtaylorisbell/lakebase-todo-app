# Databricks CLI profile pointing at your workspace.
# This is the only required setting — everything else auto-detects.
DATABRICKS_CONFIG_PROFILE=todo-app-dev

# ── Optional overrides ──────────────────────────
# Set these only if you need to bypass auto-detection.
#
# LAKEBASE_BRANCH_ID=dev-your-name     # auto-detected from email
# LAKEBASE_ENDPOINT_ID=primary         # default
# LAKEBASE_DATABASE=databricks_postgres # default
